import pymysql

database = pymysql.connect(
    host='localhost',
    user='root',
    password='Gangurde@156',
    database='demo'
)

Cursor = database.cursor()

n = int(input("Enter number of records to insert: "))

values = []

for i in range(n):
    print(f"\nEnter details for student {i+1}")
    
    prn = int(input("Enter PRN: "))
    name = input("Enter Name: ")
    subject = input("Enter Subject: ")
    
    values.append((prn, name, subject))

sql = "insert into student (prn,name,subject) values (%s,%s,%s)"

Cursor.executemany(sql, values)

database.commit()

print(Cursor.rowcount, "Inserted")

Cursor.close()
database.close()

import pymysql

database = pymysql.connect(
    host='localhost',
    user='root',
    password='Gangurde@156',
    database='demo'
)

Cursor = database.cursor()

prn = int(input("Enter PRN to delete: "))
name = input("Enter Name: ")
subject = input("Enter Subject: ")

sql = "delete from student where prn=%s and name=%s and subject=%s"

Cursor.execute(sql, (prn, name, subject))

database.commit()

print(Cursor.rowcount, "deleted")

Cursor.close()
database.close()
